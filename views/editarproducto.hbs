<h1>
    Editar producto
</h1>

<form
  action="/dashboard/productos/editar/{{producto.id_producto}}"
  method="POST"
  enctype="multipart/form-data"
  class="registro-form"
>

    <!-- NOMBRE -->

    <input
      type="text"
      value="{{producto.nombre_producto}}"
      name="nombre_producto"
      placeholder="Nombre"
      required
    >

    <!-- DESCRIPCION -->

    <textarea
      name="descripcion"
      placeholder="Descripción"
    >{{producto.descripcion}}</textarea>

    <!-- PRECIO -->

    <input
      type="number"
      step="0.01"
      value="{{producto.precio}}"
      name="precio"
      placeholder="Precio"
      required
    >

    <!-- IMAGEN ACTUAL -->

    <img
      src="{{producto.imagen}}"
      alt="producto"
      width="200"
    >

    <br><br>

    <!-- GUARDAR IMAGEN ACTUAL -->

    <input
      type="hidden"
      name="imagen_actual"
      value="{{producto.imagen}}"
    >

    <!-- NUEVA IMAGEN -->

    <input
      type="file"
      name="imagen"
      accept="image/*"
    >

    <br><br>

    <!-- CATEGORIAS -->

    <select name="id_categoria">

        {{#each categorias}}

        <option value="{{id_categoria}}">

            {{nombre_categoria}}

        </option>

        {{/each}}

    </select>

    <br><br>

    <!-- BOTON -->

    <button type="submit">

        Guardar cambios

    </button>

</form>