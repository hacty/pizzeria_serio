<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Pizzeria de confianza</title>

    <link rel="stylesheet" href="/styles/base.css">
    <link rel="stylesheet" href="/styles/components.css">
    <link rel="stylesheet" href="/styles/layout.css">
    <link rel="stylesheet" href="/styles/responsive.css">
    <link rel="icon" type="image/ico" href="https://cdn-icons-png.flaticon.com/512/1404/1404945.png">
</head>
<body>
    


        <header class="header">
  <div class="logo">
     <img src="https://cdn-icons-png.flaticon.com/512/1404/1404945.png" alt="logo">
  </div>

  <nav class="menu">
    <a href="/">Inicio</a>
    <a href="#">Servicios</a>
    <a href="#">Contacto</a>
{{#if usuario}}

  <a href="/dashboard">
    {{usuario}}
  </a>

{{else}}

  <a href="/login">
    Inicia sesión
  </a>

{{/if}}
  </nav>
</header>


    <div class="fondo"></div>
        <div class="contenido">
            <div class="caja">
    {{{body}}}
     </div>
     </div>

    <footer class="footer">

    
       <img class="logofooter" src="https://cdn-icons-png.flaticon.com/512/1404/1404945.png">
    <div class="footertexto">
            <div class="footertitle">
        Desarrollado para la gente que ama la pizza 🍕
</div>
    <p>Grupo 4 desarrollado con Redis.</p>
        <p>2026</p>
    </div>
</footer>

<script src="/js/main.js" defer></script>

